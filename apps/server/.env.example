# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://redmatrix:redmatrix@localhost:5432/redmatrix?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=7d

# WeChat MiniProgram
WX_APPID=wx_your_appid_here
WX_SECRET=wx_your_secret_here

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Tencent COS (object storage)
COS_REGION=ap-shanghai
COS_BUCKET=redmatrix-1300000000
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key

# AI quotas (per day)
AI_FREE_DAILY=3
AI_PRO_DAILY=100
AI_TEAM_DAILY=1000
