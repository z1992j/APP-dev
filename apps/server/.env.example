# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated allowed origins (empty = allow all in dev)
CORS_ORIGINS=http://localhost:3001

# Database
DATABASE_URL=postgresql://redmatrix:redmatrix@localhost:5432/redmatrix?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT — MUST be >= 32 characters. Generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production-please-at-least-32-chars
JWT_EXPIRES_IN=7d

# Docker — optional TCP endpoint (default: /var/run/docker.sock)
# DOCKER_HOST=tcp://127.0.0.1:2375

# WeChat MiniProgram
WX_APPID=wx_your_appid_here
WX_SECRET=wx_your_secret_here

# DeepSeek (Anthropic-compatible endpoint)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-pro

# Tencent COS (object storage)
COS_REGION=ap-shanghai
COS_BUCKET=redmatrix-1300000000
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key

# AI quotas (per day)
AI_FREE_DAILY=3
AI_PRO_DAILY=100
AI_TEAM_DAILY=1000
