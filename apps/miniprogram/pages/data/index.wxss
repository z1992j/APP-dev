.hero { background: linear-gradient(135deg, #3A66FF, #6A8DFF); color: #fff; }
.hero-title { font-size: 32rpx; font-weight: 600; }
.hero-sub { font-size: 26rpx; opacity: 0.85; margin-top: 8rpx; }
.hero-cta { margin-top: 32rpx; font-size: 28rpx; text-align: right; }

.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 24rpx; }

.totals { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.tot { text-align: center; }
.tot-label { color: #8E92A6; font-size: 22rpx; }
.tot-value { font-size: 38rpx; font-weight: 700; margin-top: 8rpx; }

.acct-row { display: flex; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid #ECEEF3; }
.acct-row:last-child { border: none; }
.acct-vert { color: #8E92A6; font-size: 24rpx; }
