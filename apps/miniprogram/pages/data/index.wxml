<view class="page">
  <view class="card hero" bindtap="openReport">
    <view class="hero-title">📝 今日填报</view>
    <view class="hero-sub">花 30 秒，看趋势更清晰</view>
    <view class="hero-cta">立即填 →</view>
  </view>

  <view class="card">
    <view class="card-title">全矩阵汇总</view>
    <view class="totals">
      <view class="tot">
        <view class="tot-label">总粉丝</view>
        <view class="tot-value">{{totals.followers || 0}}</view>
      </view>
      <view class="tot">
        <view class="tot-label">总曝光</view>
        <view class="tot-value">{{totals.impressions || 0}}</view>
      </view>
      <view class="tot">
        <view class="tot-label">总互动</view>
        <view class="tot-value">{{(totals.likes || 0) + (totals.saves || 0) + (totals.comments || 0)}}</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">账号 ({{accounts.length}})</view>
    <view wx:if="{{!accounts.length}}" class="txt-muted">还没有账号，先去「我」页面创建</view>
    <view wx:for="{{accounts}}" wx:key="id" class="acct-row">
      <text class="acct-name">{{item.nickname}}</text>
      <text class="acct-vert">{{item.vertical || ''}}</text>
    </view>
  </view>
</view>
