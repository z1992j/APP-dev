<view class="page">
  <view class="card profile">
    <view class="avatar">{{user.nickname[0] || '我'}}</view>
    <view class="info">
      <view class="name">{{user.nickname || '未登录'}}</view>
      <view class="plan">套餐：{{team.role === 'owner' ? '免费版' : team.role}}</view>
    </view>
  </view>

  <view class="card">
    <view class="row" bindtap="openBilling">
      <text>升级 Pro</text>
      <text class="arrow">→</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">账号档案 ({{accounts.length}})</view>
    <view wx:for="{{accounts}}" wx:key="id"
          class="row" data-id="{{item.id}}" bindtap="editAccount">
      <text>{{item.nickname}} <text class="tag">{{item.vertical || '未设置'}}</text></text>
      <text class="arrow">→</text>
    </view>
    <view class="btn-ghost" bindtap="newAccount">+ 添加账号档案</view>
  </view>

  <view class="card">
    <view class="row" bindtap="openAgreement">
      <text>用户协议 / 隐私政策</text>
      <text class="arrow">→</text>
    </view>
    <view class="row" bindtap="signOut">
      <text class="txt-danger">退出登录</text>
    </view>
  </view>
</view>
