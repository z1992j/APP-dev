.tabs { display: flex; background: #fff; padding: 16rpx; gap: 16rpx; }
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background: #F1F3F8;
  color: #444;
  font-size: 26rpx;
}
.tab.active { background: #3A66FF; color: #fff; }

.doc .h1 { font-size: 36rpx; font-weight: 700; }
.doc .meta { font-size: 22rpx; color: #8E92A6; margin: 8rpx 0 24rpx; }
.doc .h2 { font-size: 28rpx; font-weight: 600; margin: 32rpx 0 12rpx; }
.doc .p { font-size: 26rpx; line-height: 1.7; color: #333; }
.doc .bold { font-weight: 600; }
