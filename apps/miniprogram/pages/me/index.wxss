.profile { display: flex; align-items: center; gap: 24rpx; }
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #3A66FF;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.info .name { font-size: 32rpx; font-weight: 600; }
.info .plan { color: #8E92A6; font-size: 24rpx; margin-top: 8rpx; }

.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; }

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #ECEEF3;
}
.row:last-child { border: none; }
.arrow { color: #B6C2E5; }
.tag {
  display: inline-block;
  background: #F1F3F8;
  color: #555;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  margin-left: 12rpx;
}
