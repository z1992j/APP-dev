<view class="page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜笔记 / 关键词" value="{{q}}" bindinput="onInput" bindconfirm="onSearch" />
    <view class="search-btn" bindtap="onSearch">搜</view>
  </view>

  <view wx:if="{{history.length && !angles.length}}" class="card">
    <view class="card-title">最近搜过</view>
    <view class="tag-row">
      <view wx:for="{{history}}" wx:key="*this" class="tag" data-q="{{item}}" bindtap="onHistoryTap">{{item}}</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card txt-muted">生成中…</view>

  <view wx:if="{{angles.length}}" class="card">
    <view class="card-title">10 个选题角度</view>
    <view class="angle-list">
      <view wx:for="{{angles}}" wx:key="id" class="angle-item" data-text="{{item.text}}" bindtap="onUseAngle">
        <text class="angle-text">{{item.text}}</text>
        <text class="angle-cta">用这条写作 →</text>
      </view>
    </view>
  </view>

  <view wx:if="{{userNotes.length}}" class="card">
    <view class="card-title">我的选题池</view>
    <view wx:for="{{userNotes}}" wx:key="fingerprint" class="pool-item">
      <text>{{item.url || item.title || '已收藏笔记'}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">快速创作</view>
    <view class="btn-primary" bindtap="onWriteCta">+ 用 AI 写一篇</view>
    <view class="divider"></view>
    <view class="btn-ghost" bindtap="onPasteOembed">粘贴小红书笔记链接收藏</view>
  </view>
</view>
