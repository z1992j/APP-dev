.label { font-size: 26rpx; color: #8E92A6; margin: 24rpx 0 12rpx; }
.topic-input {
  background: #F1F3F8;
  border-radius: 16rpx;
  padding: 24rpx;
  min-height: 100rpx;
}
.account-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.account-chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #F1F3F8;
  color: #444;
  font-size: 26rpx;
}
.account-chip.active { background: #3A66FF; color: #fff; }
.tag-row { display: flex; flex-wrap: wrap; gap: 12rpx; }

.result-card { border: 1rpx solid #ECEEF3; }
.result-header { display: flex; justify-content: space-between; align-items: center; }
.result-account { font-weight: 600; }
.result-status { color: #8E92A6; font-size: 24rpx; }

.title-option {
  padding: 18rpx 24rpx;
  border-radius: 12rpx;
  background: #F7F8FA;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}
.title-option.active {
  background: #E6ECFF;
  border: 1rpx solid #3A66FF;
}
.body-preview {
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  white-space: pre-wrap;
  line-height: 1.6;
}
.hashtags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.streaming {
  background: #F7F8FA;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #555;
  white-space: pre-wrap;
  min-height: 100rpx;
}
