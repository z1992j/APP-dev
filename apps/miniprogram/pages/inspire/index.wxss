.search-bar {
  display: flex;
  background: #fff;
  padding: 20rpx 32rpx;
  align-items: center;
}
.search-input {
  flex: 1;
  background: #F1F3F8;
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
}
.search-btn {
  margin-left: 20rpx;
  padding: 14rpx 28rpx;
  background: #3A66FF;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.tag-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.angle-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #ECEEF3;
}
.angle-item:last-child { border: none; }
.angle-text { font-size: 28rpx; flex: 1; }
.angle-cta { color: #3A66FF; font-size: 24rpx; margin-left: 16rpx; }
.pool-item {
  font-size: 26rpx;
  color: #555;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #ECEEF3;
  word-break: break-all;
}
