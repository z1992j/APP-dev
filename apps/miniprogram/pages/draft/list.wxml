<view class="page">
  <view class="filter-row">
    <view wx:for="{{statuses}}" wx:key="key"
          class="filter-chip {{status === item.key ? 'active' : ''}}"
          data-key="{{item.key}}" bindtap="pickStatus">{{item.label}}</view>
  </view>

  <view wx:if="{{!items.length && !loading}}" class="empty">
    <view class="empty-title">还没有草稿</view>
    <view class="btn-primary" bindtap="newDraft">写第一篇 →</view>
  </view>

  <view wx:for="{{items}}" wx:key="id" class="card draft-card" data-id="{{item.id}}" bindtap="open">
    <view class="row top">
      <text class="status-tag status-{{item.status}}">{{statusLabel[item.status] || item.status}}</text>
      <text class="account">{{item.account.nickname}}</text>
    </view>
    <view class="title">{{item.title || '(未命名)'}}</view>
    <view class="body-preview">{{item.body}}</view>
  </view>

  <view wx:if="{{loading}}" class="txt-muted center">加载中…</view>
  <view class="fab" bindtap="newDraft">+</view>
</view>
