.status-row { display: flex; justify-content: space-between; color: #8E92A6; font-size: 24rpx; }
.label { font-size: 26rpx; color: #8E92A6; margin: 24rpx 0 12rpx; }
.title-input, .input {
  background: #F1F3F8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
}
.body-input {
  background: #F1F3F8;
  border-radius: 12rpx;
  padding: 24rpx;
  min-height: 240rpx;
  font-size: 28rpx;
  line-height: 1.6;
}
.media-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.media-cell {
  position: relative;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #F1F3F8;
}
.media-cell.add {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #B6C2E5;
}
.media-img { width: 100%; height: 100%; }
.media-x {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.actions { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 99;
}
.sheet {
  width: 100%;
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  padding: 32rpx;
  max-height: 70vh;
  overflow-y: auto;
}
.sheet-header {
  display: flex;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.sheet-x { color: #8E92A6; font-size: 40rpx; }
.violation {
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: #F7F8FA;
}
.v-head { display: flex; gap: 12rpx; align-items: center; margin-bottom: 8rpx; }
.v-level { font-size: 24rpx; }
.v-term { font-weight: 600; }
.v-cat { color: #8E92A6; font-size: 22rpx; }
.v-suggest { color: #444; font-size: 26rpx; margin-bottom: 16rpx; }
.btn-ghost.sm { padding: 12rpx; font-size: 26rpx; display: inline-block; }
