/* Global tokens */
page {
  background: #F7F8FA;
  color: #1F1F1F;
  font-size: 28rpx;
  font-family: -apple-system, "PingFang SC", "Source Han Sans CN", sans-serif;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  background: #3A66FF;
  color: #fff;
  border-radius: 16rpx;
  text-align: center;
  padding: 24rpx;
  font-weight: 600;
}
.btn-primary[disabled] {
  background: #B6C2E5;
}

.btn-ghost {
  background: #F1F3F8;
  color: #1F1F1F;
  border-radius: 16rpx;
  text-align: center;
  padding: 24rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #F1F3F8;
  color: #555;
  font-size: 22rpx;
  margin-right: 12rpx;
}
.tag.active {
  background: #3A66FF;
  color: #fff;
}

.txt-muted { color: #8E92A6; }
.txt-danger { color: #FF4D4F; }
.txt-warn { color: #FAAD14; }

.divider {
  height: 1rpx;
  background: #ECEEF3;
  margin: 24rpx 0;
}
